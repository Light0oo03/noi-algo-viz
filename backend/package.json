{
  "name": "noi-algo-viz-backend",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "pnpm db:push && tsx watch src/main.ts",
    "build": "node scripts/adjust-schema.js && prisma generate && tsc -p tsconfig.json",
    "start": "echo 'Running DB Push...' && prisma db push --accept-data-loss && echo 'Starting App...' && node dist/main.js",
    "prisma": "prisma",
    "db:push": "prisma db push",
    "generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/client": "^6.13.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.1",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "@types/node": "^24.10.1",
    "@types/jsonwebtoken": "^9.0.10",
    "tsx": "^4.20.2",
    "prisma": "^6.13.0",
    "typescript": "~5.9.3"
  },
  "devDependencies": {},
  "packageManager": "pnpm@7.33.5+sha512.4e499f22fffe5845aa8f9463e1386b2d72c3134e0ebef9409360ad844fef0290e82b479b32eb2ec0f30e56607e1820c22167829fd62656d41a8fd0cc4a0f4267"
