generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  graph  UserGraph?
  tree   UserTree?
  search UserSearch?
  sort   UserSort?
}

model UserGraph {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  graphJson String
  updatedAt DateTime @updatedAt
}

model UserTree {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  treeJson  String
  updatedAt DateTime @updatedAt
}

model UserSearch {
  userId      String   @id
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  searchJson  String
  updatedAt   DateTime @updatedAt
}

model UserSort {
  userId      String   @id
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sortJson    String
  updatedAt   DateTime @updatedAt
}
